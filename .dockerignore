# Git
.git/
.gitignore

# Python 캐시
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# 가상환경
.venv/
venv/
env/

# HuggingFace 모델 캐시 (컨테이너 내부 볼륨으로 관리)
.cache/

# 데이터 (볼륨 마운트로 공유)
data/raw/
data/index/

# 개발 도구
.claude/
.vscode/
.idea/

# 문서/설계 파일
docs/
*.md
!README.md

# Windows 스크립트 (컨테이너에서 불필요)
*.bat
ngrok.exe

# 환경변수 (docker-compose에서 볼륨 마운트로 주입)
.env
.env.*
!.env.example

# 테스트/평가 픽스처
scripts/eval-fixture*.json

# 임시 파일
*.log
*.tmp
