# LLM 설정 (베이스 URL만 입력하면 자동으로 /chat/completions 경로 추가)
LLM_ENDPOINT=http://your-endpoint/v1
LLM_MODEL=Qwen/Qwen3.5-9B
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# Embedding 설정
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunking 설정
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# Vector Index 설정
TOP_K=5
IVF_N_CLUSTERS=16

# Session 설정
MAX_HISTORY_TURNS=10
SESSION_TTL_SECONDS=3600

# Cache 설정
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_MAX_SIZE=200

# 서버 설정
HOST=0.0.0.0
PORT=8000
