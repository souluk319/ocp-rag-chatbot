# LLM 설정 (기본 엔드포인트)
LLM_ENDPOINT=http://localhost:8080/v1
LLM_MODEL=Qwen/Qwen3.5-9B
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# LLM 엔드포인트 목록 (UI에서 선택 가능)
# 엔드포인트를 추가/변경하려면 아래 패턴으로 .env에 설정
# LLM_EP_{KEY}_NAME=표시 이름
# LLM_EP_{KEY}_URL=http://서버주소:포트/v1
# LLM_EP_{KEY}_MODEL=모델명
LLM_EP_COMPANY_NAME=회사 서버
LLM_EP_COMPANY_URL=http://your-company-server/v1
LLM_EP_COMPANY_MODEL=Qwen/Qwen3.5-9B

LLM_EP_MACMINI_NAME=Mac Mini
LLM_EP_MACMINI_URL=http://your-macmini-ip:8080/v1
LLM_EP_MACMINI_MODEL=Qwen/Qwen3.5-9B-4bit

LLM_EP_RTX_NAME=RTX Desktop
LLM_EP_RTX_URL=http://your-rtx-ip:8080/v1
LLM_EP_RTX_MODEL=Qwen/Qwen3.5-9B-4bit

# Embedding 설정
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# Chunking 설정
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# 데이터 경로
DATA_CORPUS_DIR=/path/to/ocp-rag-chatbot/data/sanitized_raw

# Vector Index 설정
TOP_K=5
IVF_N_CLUSTERS=16
IVF_N_PROBE=6

# Session 설정
MAX_HISTORY_TURNS=10
SESSION_TTL_SECONDS=3600

# Cache 설정
CACHE_SIMILARITY_THRESHOLD=0.95
CACHE_MAX_SIZE=200

# 서버 설정
HOST=0.0.0.0
PORT=8000
