# Paths to external repos or mirrored document trees
OPENDOCUMENTS_PATH=../OpenDocuments
OPENSHIFT_DOCS_PATH=../openshift-docs
INTERNAL_OCP_DOCS_PATH=../internal-ocp-docs

# Local working directories inside this repository
NORMALIZED_DATA_DIR=./data/normalized
MANIFEST_DIR=./data/manifests
PACKAGE_DIR=./data/packages
INDEX_DIR=./indexes

# Assistant defaults
ANSWER_LANGUAGE=ko
DEFAULT_PRODUCT=ocp
DEFAULT_VERSION=4.x
DEFAULT_MODE=operations

# Approved runtime contract for the integrated OpenDocuments path
# The bridge reads OD_* first, then falls back to LLM_* where documented.
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_ENDPOINT=
LLM_MODEL=
LLM_EP_COMPANY_NAME=
LLM_EP_COMPANY_URL=
LLM_EP_COMPANY_MODEL=
LLM_EP_COMPANY_BEARER_TOKEN=
OD_CHAT_MODEL=
OD_EMBEDDING_MODEL=
OD_COMPANY_BASE_URL=
OD_COMPANY_BEARER_TOKEN=
OD_ALLOW_LOCAL_CHAT_FALLBACK=0
OD_BRIDGE_TIMEOUT_SECONDS=120
EMBEDDING_MODEL=

# Closed-network bundle flow
OUTBOUND_BUNDLE_DIR=./data/packages/outbound
INBOUND_BUNDLE_DIR=./data/packages/inbound
