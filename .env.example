# Optional external artifact paths
# macOS/Linux example:
# ARTIFACTS_DIR=../ocp-rag-chatbot-data
# RAW_HTML_DIR=../ocp-rag-chatbot-raw/part1/raw_html
#
# Windows example (use forward slashes):
# ARTIFACTS_DIR=C:/Users/<user>/cywell/ocp-rag-chatbot-data
# RAW_HTML_DIR=C:/Users/<user>/cywell/ocp-rag-chatbot-raw/part1/raw_html
# SOURCE_MANIFEST_PATH=C:/Users/<user>/cywell/ocp-rag-chatbot-v2/manifests/ocp_ko_4_20_approved_ko.json

# Optional approved-corpus manifest
# SOURCE_MANIFEST_PATH=manifests/ocp_ko_4_20_approved_ko.json

# Embedding
EMBEDDING_BASE_URL=http://100.99.152.52:8091/v1
EMBEDDING_MODEL=dragonkue/bge-m3-ko
# EMBEDDING_API_KEY=<optional-bearer-token>
EMBEDDING_BATCH_SIZE=32

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=openshift_docs
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE=Cosine
QDRANT_UPSERT_BATCH_SIZE=128
QDRANT_RECREATE_COLLECTION=true

# LLM
LLM_ENDPOINT=http://cllm.cywell.co.kr/v1
# LLM_API_KEY=<required-if-endpoint-needs-bearer-auth>
LLM_MODEL=Qwen/Qwen3.5-9B

# RAGAS Judge
# OPENAI_API_KEY=<required-for-ragas-judge>
# OPENAI_BASE_URL=<optional-openai-compatible-base-url>
OPENAI_JUDGE_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
