# Paths to external repos or mirrored document trees
OPENDOCUMENTS_PATH=../OpenDocuments
OPENSHIFT_DOCS_PATH=../openshift-docs
INTERNAL_OCP_DOCS_PATH=../internal-ocp-docs

# Local working directories inside this repository
NORMALIZED_DATA_DIR=./data/normalized
MANIFEST_DIR=./data/manifests
PACKAGE_DIR=./data/packages
INDEX_DIR=./indexes

# Assistant defaults
ANSWER_LANGUAGE=ko
DEFAULT_PRODUCT=ocp
DEFAULT_VERSION=4.x
DEFAULT_MODE=operations

# Approved runtime contract for the integrated OpenDocuments path
# The bridge reads OD_* first, then falls back to LLM_* where documented.
# planB 기준: chat는 회사 엔드포인트를 경유하고,
# embeddings는 로컬 BGE-m3를 사용한다.
# OpenDocuments는 로컬 bridge `/v1/chat/completions`, `/v1/embeddings`만 바라본다.
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_ENDPOINT=
LLM_MODEL=
LLM_EP_COMPANY_NAME=
LLM_EP_COMPANY_URL=
LLM_EP_COMPANY_MODEL=
LLM_EP_COMPANY_BEARER_TOKEN=
OD_CHAT_MODEL=
OD_EMBEDDING_MODEL=BAAI/bge-m3
OD_EMBEDDING_DIMENSIONS=1024
OD_COMPANY_BASE_URL=
OD_COMPANY_BEARER_TOKEN=
OD_SERVER_BASE_URL=
OD_DEFAULT_MODE=operations
OD_ALLOW_LOCAL_CHAT_FALLBACK=0
OD_FORWARD_CLIENT_AUTH=0
OD_BRIDGE_TIMEOUT_SECONDS=120
OD_QUERY_CACHE_TTL_SECONDS=300
OD_QUERY_CACHE_MAX_ITEMS=256
OD_EMBEDDING_CACHE_TTL_SECONDS=3600
OD_EMBEDDING_CACHE_MAX_ITEMS=1024
EMBEDDING_MODEL=BAAI/bge-m3

# Closed-network bundle flow
OUTBOUND_BUNDLE_DIR=./data/packages/outbound
INBOUND_BUNDLE_DIR=./data/packages/inbound
APPROVED_BUNDLE_DIR=./data/packages/approved
ARCHIVE_BUNDLE_DIR=./data/packages/archive
