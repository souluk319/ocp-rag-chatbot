{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://play-book-studio.local/schemas/parsed_artifact.schema.json",
  "title": "Play Book Studio Bronze Parsed Artifact",
  "description": "Parser-routed intermediate artifact between bronze_raw and silver_structured.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "parsed_artifact_id",
    "source_ref",
    "raw_asset_ref",
    "parser_route",
    "parser_backend",
    "parser_version",
    "ocr_used",
    "page_refs",
    "quality_state",
    "security_envelope",
    "promotion_trace"
  ],
  "properties": {
    "parsed_artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "source_ref": {
      "$ref": "#/$defs/sourceRef"
    },
    "raw_asset_ref": {
      "$ref": "#/$defs/rawAssetRef"
    },
    "parser_route": {
      "type": "string",
      "minLength": 1
    },
    "parser_backend": {
      "type": "string",
      "minLength": 1
    },
    "parser_version": {
      "type": "string",
      "minLength": 1
    },
    "ocr_strategy": {
      "type": "string"
    },
    "ocr_used": {
      "type": "boolean"
    },
    "page_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/pageRef"
      }
    },
    "layout_blocks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/layoutBlock"
      }
    },
    "table_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tableRef"
      }
    },
    "figure_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/figureRef"
      }
    },
    "section_trace_hints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sectionTraceHint"
      }
    },
    "language_state": {
      "type": "string"
    },
    "quality_state": {
      "$ref": "#/$defs/qualityState"
    },
    "security_envelope": {
      "$ref": "#/$defs/securityEnvelope"
    },
    "promotion_trace": {
      "$ref": "#/$defs/promotionTrace"
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_type",
        "source_lane",
        "source_collection",
        "product",
        "version",
        "locale"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "minLength": 1
        },
        "source_lane": {
          "type": "string",
          "minLength": 1
        },
        "source_collection": {
          "type": "string",
          "minLength": 1
        },
        "product": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "locale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rawAssetRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_asset_uri",
        "source_fingerprint",
        "raw_asset_hash"
      ],
      "properties": {
        "raw_asset_uri": {
          "type": "string",
          "minLength": 1
        },
        "source_fingerprint": {
          "type": "string",
          "minLength": 1
        },
        "raw_asset_hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "pageRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_id",
        "page_no"
      ],
      "properties": {
        "page_id": {
          "type": "string",
          "minLength": 1
        },
        "page_no": {
          "type": "integer",
          "minimum": 1
        },
        "asset_ref": {
          "type": "string"
        },
        "text_length": {
          "type": "integer",
          "minimum": 0
        },
        "ocr_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "layoutBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "block_id",
        "page_no",
        "kind"
      ],
      "properties": {
        "block_id": {
          "type": "string",
          "minLength": 1
        },
        "page_no": {
          "type": "integer",
          "minimum": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "bbox": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "text": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "tableRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "table_id",
        "page_no"
      ],
      "properties": {
        "table_id": {
          "type": "string",
          "minLength": 1
        },
        "page_no": {
          "type": "integer",
          "minimum": 1
        },
        "caption": {
          "type": "string"
        }
      }
    },
    "figureRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "figure_id",
        "page_no"
      ],
      "properties": {
        "figure_id": {
          "type": "string",
          "minLength": 1
        },
        "page_no": {
          "type": "integer",
          "minimum": 1
        },
        "caption": {
          "type": "string"
        }
      }
    },
    "sectionTraceHint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_id",
        "page_no"
      ],
      "properties": {
        "section_id": {
          "type": "string",
          "minLength": 1
        },
        "page_no": {
          "type": "integer",
          "minimum": 1
        },
        "block_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "qualityState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parse_status",
        "review_status",
        "trust_score",
        "updated_at"
      ],
      "properties": {
        "parse_status": {
          "type": "string",
          "minLength": 1
        },
        "review_status": {
          "type": "string",
          "minLength": 1
        },
        "trust_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "updated_at": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "securityEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "workspace_id",
        "pack_id",
        "classification",
        "access_groups",
        "provider_egress_policy",
        "redaction_state"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "workspace_id": {
          "type": "string",
          "minLength": 1
        },
        "pack_id": {
          "type": "string",
          "minLength": 1
        },
        "classification": {
          "type": "string",
          "minLength": 1
        },
        "access_groups": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "provider_egress_policy": {
          "type": "string",
          "minLength": 1
        },
        "redaction_state": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "promotionTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_stage",
        "target_stage",
        "decision",
        "updated_at"
      ],
      "properties": {
        "source_stage": {
          "type": "string",
          "minLength": 1
        },
        "target_stage": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "updated_at": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
