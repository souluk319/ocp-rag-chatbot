{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OCP RAG Evaluation Fixture",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "mode_hint",
      "query_class",
      "language",
      "conversation",
      "expected",
      "tags"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "mode_hint": {
        "type": "string",
        "enum": [
          "education",
          "operations"
        ]
      },
      "query_class": {
        "type": "string",
        "enum": [
          "overview",
          "education",
          "operations",
          "troubleshooting"
        ]
      },
      "language": {
        "type": "string",
        "enum": [
          "ko",
          "en",
          "mixed"
        ]
      },
      "conversation": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": [
            "role",
            "content"
          ],
          "properties": {
            "role": {
              "type": "string",
              "enum": [
                "user",
                "assistant"
              ]
            },
            "content": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "expected": {
        "type": "object",
        "required": [
          "retrieval",
          "answer"
        ],
        "properties": {
          "rewrite": {
            "type": "object",
            "properties": {
              "should_change": {
                "type": "boolean"
              },
              "must_equal": {
                "type": "string"
              },
              "must_include_any": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "must_not_include_any": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          },
          "retrieval": {
            "type": "object",
            "required": [
              "source_any"
            ],
            "properties": {
              "source_any": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "source_prefer_top3": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "source_exclude_top3": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "min_distinct_sources": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          },
          "answer": {
            "type": "object",
            "required": [
              "must_include_any",
              "must_not_include_any",
              "citation_required",
              "requires_step_list",
              "requires_command_example"
            ],
            "properties": {
              "must_include_any": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "should_include_any": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "must_not_include_any": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "citation_required": {
                "type": "boolean"
              },
              "requires_step_list": {
                "type": "boolean"
              },
              "requires_command_example": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "tags": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string"
        }
      },
      "notes": {
        "type": "string"
      }
    },
    "additionalProperties": false
  }
}
