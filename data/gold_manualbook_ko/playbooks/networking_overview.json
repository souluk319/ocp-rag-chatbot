      "viewer_path": "/docs/ocp/4.20/ko/networking_overview/index.html#accessing-hosts-on-aws_accessing-hosts",
      "semantic_role": "procedure",
      "block_kinds": [
        "paragraph",
        "paragraph",
        "paragraph",
        "paragraph",
        "paragraph",
        "paragraph",
