{
  "timezone": "Asia/Seoul",
  "jobs": {
    "manifest_refresh": {
      "name": "Manifest Refresh",
      "stage": "catalog",
      "inputs": [
        "manifests/ocp_multiversion_html_single_catalog.json"
      ],
      "outputs": [
        "manifests/ocp_multiversion_html_single_catalog.json",
        "reports/build_logs/source_manifest_update_report.json"
      ],
      "stop_on_failure": true
    },
    "high_value_ingestion": {
      "name": "High-Value Ingestion",
      "stage": "ingestion",
      "inputs": [
        "manifests/ocp_ko_4_20_approved_ko.json",
        "data/bronze/raw_html/*.html"
      ],
      "outputs": [
        "data/silver/normalized_docs.jsonl",
        "data/gold_corpus_ko/chunks.jsonl",
        "data/gold_manualbook_ko/playbook_documents.jsonl",
        "reports/build_logs/preprocessing_log.json"
      ],
      "stop_on_failure": true
    },
    "source_approval": {
      "name": "Source Approval",
      "stage": "approval",
      "inputs": [
        "data/silver/normalized_docs.jsonl",
        "data/gold_corpus_ko/chunks.jsonl",
        "data/gold_manualbook_ko/playbook_documents.jsonl"
      ],
      "outputs": [
        "manifests/ocp_ko_4_20_approved_ko.json",
        "reports/build_logs/source_approval_report.json",
        "reports/build_logs/translation_lane_report.json",
        "reports/build_logs/high_value_gap_report.json"
      ],
      "stop_on_failure": true
    },
    "approved_runtime_rebuild": {
      "name": "Approved Runtime Rebuild",
      "stage": "rebuild",
      "inputs": [
        "manifests/ocp_ko_4_20_approved_ko.json",
        "data/bronze/raw_html/*.html"
      ],
      "outputs": [
        "data/silver/normalized_docs.jsonl",
        "data/gold_corpus_ko/chunks.jsonl",
        "data/gold_manualbook_ko/playbook_documents.jsonl",
        "reports/build_logs/preprocessing_log.json",
        "qdrant:openshift_docs"
      ],
      "stop_on_failure": true
    },
    "source_bundle_harvest": {
      "name": "Source Bundle Harvest",
      "stage": "bronze",
      "inputs": [
        "reports/build_logs/high_value_gap_report.json",
        "manifests/ocp_multiversion_html_single_catalog.json"
      ],
      "outputs": [
        "data/bronze/source_bundles/*/bundle_manifest.json",
        "data/bronze/source_bundles/*/dossier.json",
        "reports/build_logs/source_bundle_batch_live.json"
      ],
      "stop_on_failure": false
    },
    "source_bundle_quality": {
      "name": "Source Bundle Quality",
      "stage": "bronze_quality",
      "inputs": [
        "data/bronze/source_bundles/*/bundle_manifest.json",
        "data/bronze/source_bundles/*/dossier.json"
      ],
      "outputs": [
        "reports/build_logs/source_bundle_quality_live.json"
      ],
      "stop_on_failure": true
    },
    "synthesis_lane": {
      "name": "Synthesis Lane",
      "stage": "planning",
      "inputs": [
        "reports/build_logs/source_bundle_quality_live.json",
        "manifests/ocp_ko_4_20_approved_ko.json"
      ],
      "outputs": [
        "manifests/ocp_ko_4_20_translated_ko_draft.json",
        "manifests/ocp_ko_4_20_corpus_working_set.json",
        "reports/build_logs/synthesis_lane_live.json"
      ],
      "stop_on_failure": true
    },
    "translation_drafts": {
      "name": "Translation Drafts",
      "stage": "silver_ko",
      "inputs": [
        "manifests/ocp_ko_4_20_translated_ko_draft.json"
      ],
      "outputs": [
        "data/silver_ko/translation_drafts/normalized_docs.jsonl",
        "data/silver_ko/translation_drafts/chunks.jsonl",
        "data/silver_ko/translation_drafts/playbook_documents.jsonl",
        "reports/build_logs/translation_draft_generation_report.json"
      ],
      "stop_on_failure": true
    },
    "translation_gold_promotion": {
      "name": "Translation Gold Promotion",
      "stage": "promotion",
      "inputs": [
        "data/silver_ko/translation_drafts/normalized_docs.jsonl",
        "data/silver_ko/translation_drafts/chunks.jsonl",
        "data/silver_ko/translation_drafts/playbook_documents.jsonl",
        "manifests/ocp_ko_4_20_translated_ko_draft.json"
      ],
      "outputs": [
        "manifests/ocp_ko_4_20_approved_ko.json",
        "data/silver/normalized_docs.jsonl",
        "data/gold_corpus_ko/chunks.jsonl",
        "data/gold_manualbook_ko/playbook_documents.jsonl",
        "qdrant:openshift_docs",
        "reports/build_logs/translation_gold_promotion_report.json"
      ],
      "stop_on_failure": true
    },
    "validation_gate": {
      "name": "Validation Gate",
      "stage": "judge",
      "inputs": [
        "data/silver/normalized_docs.jsonl",
        "data/gold_corpus_ko/chunks.jsonl",
        "data/gold_manualbook_ko/playbook_documents.jsonl",
        "manifests/ocp_ko_4_20_approved_ko.json"
      ],
      "outputs": [
        "reports/build_logs/validation_report.json"
      ],
      "stop_on_failure": true
    },
    "data_quality_audit": {
      "name": "Data Quality Audit",
      "stage": "judge",
      "inputs": [
        "data/silver/normalized_docs.jsonl",
        "data/gold_corpus_ko/chunks.jsonl",
        "data/gold_manualbook_ko/playbook_documents.jsonl",
        "data/bronze/raw_html/*.html"
      ],
      "outputs": [
        "reports/build_logs/data_quality_report.json"
      ],
      "stop_on_failure": true
    },
    "runtime_smoke": {
      "name": "Runtime Smoke",
      "stage": "runtime",
      "inputs": [
        "http://127.0.0.1:8765/api/health",
        "runtime endpoints"
      ],
      "outputs": [
        "reports/build_logs/runtime_report.json"
      ],
      "stop_on_failure": false
    }
  },
  "profiles": [
    {
      "id": "runtime_smoke_hourly",
      "name": "Runtime Smoke Hourly",
      "description": "Probe UI, LLM, embedding, and Qdrant reachability every hour to catch runtime regressions first.",
      "schedule": {
        "cadence": "hourly",
        "minute": 15,
        "interval_hours": 1
      },
      "jobs": [
        "runtime_smoke"
      ]
    },
    {
      "id": "nightly_refresh",
      "name": "Nightly Foundry Refresh",
      "description": "Refresh source readiness, rebuild working manifests, generate draft artifacts, and write judge reports.",
      "schedule": {
        "cadence": "daily",
        "days": [
          "Mon",
          "Tue",
          "Wed",
          "Thu",
          "Fri",
          "Sat",
          "Sun"
        ],
        "time": "01:30"
      },
      "jobs": [
        "source_bundle_harvest",
        "source_bundle_quality",
        "synthesis_lane",
        "translation_drafts",
        "approved_runtime_rebuild",
        "translation_gold_promotion",
        "source_approval",
        "validation_gate",
        "data_quality_audit",
        "runtime_smoke"
      ]
    },
    {
      "id": "morning_gate",
      "name": "Morning Gold Gate",
      "description": "Summarize current promotion queues and produce a release-blocking verdict before the workday starts.",
      "schedule": {
        "cadence": "daily",
        "days": [
          "Mon",
          "Tue",
          "Wed",
          "Thu",
          "Fri"
        ],
        "time": "08:30"
      },
      "jobs": [
        "source_approval",
        "source_bundle_quality",
        "synthesis_lane",
        "validation_gate",
        "data_quality_audit",
        "runtime_smoke"
      ]
    },
    {
      "id": "weekly_high_value_rebuild",
      "name": "Weekly High-Value Rebuild",
      "description": "Refresh the catalog, rebuild the high-value pack, regenerate readiness queues, and publish a weekly verdict.",
      "schedule": {
        "cadence": "weekly",
        "days": [
          "Sun"
        ],
        "time": "03:00"
      },
      "jobs": [
        "manifest_refresh",
        "high_value_ingestion",
        "source_approval",
        "source_bundle_harvest",
        "source_bundle_quality",
        "synthesis_lane",
        "translation_drafts",
        "approved_runtime_rebuild",
        "validation_gate",
        "data_quality_audit",
        "runtime_smoke"
      ]
    }
  ]
}
